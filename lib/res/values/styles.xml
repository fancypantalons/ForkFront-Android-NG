<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ForkFront" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hearse_accent</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <style name="NH_Dialog" parent="Theme.AppCompat.DayNight.Dialog">
        <item name="android:background">@android:drawable/alert_dark_frame</item>
    </style>
    
    <style name="WindowText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:typeface">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/hearse_text</item>
    </style>    

    <style name="DialogTitle" parent="TextAppearance.AppCompat.Medium">
        <item name="android:typeface">sans</item>
        <item name="android:textSize">18sp</item>
    </style>    

    <style name="DialogText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:typeface">sans</item>
        <item name="android:textSize">16sp</item>
    </style>    

    <style name="ButtonText" parent="Widget.AppCompat.Button">
        <item name="android:ellipsize">end</item>
        <item name="android:lines">1</item>
        <item name="android:scrollHorizontally">true</item> 
    </style>

    <style name="InputText" parent="Widget.AppCompat.EditText">
    </style>   

    <style name="dPadBtn" parent="Widget.AppCompat.Button">
        <item name="android:typeface">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">none</item>
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ListText1" parent="TextAppearance.AppCompat.Medium">
        <item name="android:typeface">sans</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ListText2" parent="TextAppearance.AppCompat.Medium">
        <item name="android:typeface">sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>    

</resources>
