<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:id="@+id/character_row_root"
	android:orientation="horizontal"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:minHeight="56dp"
	android:gravity="center_vertical"
	android:paddingStart="@dimen/padding_large"
	android:paddingEnd="@dimen/padding_large"
	android:paddingTop="@dimen/padding_small"
	android:paddingBottom="@dimen/padding_small"
	android:background="?attr/selectableItemBackground"
	android:foreground="@drawable/gamepad_focus_selector"
	android:focusable="true"
	android:clickable="true">

	<TextView
		android:id="@+id/character_identity"
		style="@style/ListText1"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_weight="1"
		android:ellipsize="end"
		android:maxLines="1"
		android:textColor="?attr/colorOnSurface"/>

	<LinearLayout
		android:id="@+id/chip_container"
		android:orientation="horizontal"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:visibility="gone">

		<TextView
			android:id="@+id/chip_race"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:background="@drawable/chip_background"
			android:paddingStart="10dp"
			android:paddingEnd="10dp"
			android:paddingTop="4dp"
			android:paddingBottom="4dp"
			android:layout_marginStart="@dimen/padding_small"
			android:textAppearance="?attr/textAppearanceBodySmall"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:gravity="center"/>

		<TextView
			android:id="@+id/chip_alignment"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:background="@drawable/chip_background"
			android:paddingStart="10dp"
			android:paddingEnd="10dp"
			android:paddingTop="4dp"
			android:paddingBottom="4dp"
			android:layout_marginStart="@dimen/padding_small"
			android:textAppearance="?attr/textAppearanceBodySmall"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:gravity="center"/>

		<TextView
			android:id="@+id/chip_wizard"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:background="@drawable/chip_background"
			android:paddingStart="10dp"
			android:paddingEnd="10dp"
			android:paddingTop="4dp"
			android:paddingBottom="4dp"
			android:layout_marginStart="@dimen/padding_small"
			android:textAppearance="?attr/textAppearanceBodySmall"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:gravity="center"
			android:text="Wizard"
			android:visibility="gone"/>

	</LinearLayout>

</LinearLayout>
