<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/base_frame"
    android:background="@color/hearse_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:orientation="vertical" >

    <FrameLayout
        android:id="@+id/dlg_frame"
        android:layout_width="match_parent"
        android:layout_height="@dimen/padding_small"
        android:layout_weight="1" >

        <FrameLayout
            android:id="@+id/map_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="blocksDescendants" >

            <com.tbd.forkfront.WidgetLayout
                android:id="@+id/widgetLayout1"
                android:layout_width="match_parent"
                android:layout_height="match_parent" >

                <!-- Emergency Settings Access -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|right"
                    android:layout_marginTop="100dp"
                    android:layout_marginRight="16dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_add_widget"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_add"
                        android:contentDescription="Add Widget"
                        android:elevation="10dp" />

                    <ImageButton
                        android:id="@+id/btn_save_layout"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginLeft="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_save"
                        android:contentDescription="Save Layout"
                        android:visibility="gone"
                        android:elevation="10dp" />

                    <ImageButton
                        android:id="@+id/emergency_settings"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginLeft="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_preferences"
                        android:contentDescription="Settings"
                        android:elevation="10dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|fill_horizontal"
                    android:orientation="vertical" >

                    <com.tbd.forkfront.AutoFitTextView
                        android:id="@+id/nh_stat0"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp" />

                    <com.tbd.forkfront.AutoFitTextView
                        android:id="@+id/nh_stat1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp" />

                    <com.tbd.forkfront.NH_TextView
                        android:id="@+id/nh_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp" />

                    <com.tbd.forkfront.NH_TextView
                        android:id="@+id/more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--More--"
                        android:background="@android:color/background_light"
                        android:textColor="@android:color/black"
                        android:clickable="true"
                        android:visibility="gone"
                        android:textSize="15sp" />
                </LinearLayout>

                <com.tbd.forkfront.NH_TextView
                    android:id="@+id/nh_blockmsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center"
					android:paddingBottom="@dimen/padding_medium"
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:text="Tap to continue"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <include
                    android:id="@+id/dpad"
                    layout="@layout/dpad_ovl" />

				
                <LinearLayout
                     android:id="@+id/viewArea"
                     android:layout_width="match_parent"
                     android:layout_height="match_parent"
                     android:orientation="horizontal"/>

            </com.tbd.forkfront.WidgetLayout>
        </FrameLayout>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/window_fragment_host"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/kbd_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom" />

    <!-- Asset Loading Overlay -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#FF424242"
            android:elevation="16dp"
            android:padding="24dp">

            <TextView
                android:id="@+id/loading_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preparing NetHack content..."
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/asset_progress"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"/>

            <TextView
                android:id="@+id/progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:text="0%"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>